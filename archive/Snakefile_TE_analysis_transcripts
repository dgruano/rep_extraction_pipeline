rule run_repeatmasker_on_transcripts:
    """Run RepeatMasker on transcript FASTA files (faster than genome)."""
    input:
        fasta = "{fasta_file}",
        index = "{fasta_file}.fai"
    output:
        gff = "{output_dir}/repeatmasker/{prefix}.out.gff",
        out = "{output_dir}/repeatmasker/{prefix}.out",
        masked = "{output_dir}/repeatmasker/{prefix}.masked"
    params:
        species = RM_SPECIES,
        outdir = "{output_dir}/repeatmasker",
        prefix = "{prefix}"
    threads: THREADS
    log:
        "{output_dir}/logs/repeatmasker_{prefix}.log"
    shell:
        """
        RepeatMasker \
            -species {params.species} \
            -pa {threads} \
            -gff \
            -dir {params.outdir} \
            -s \
            {input.fasta} \
            2>&1 | tee {log}

        # Rename outputs to standardized names
        mv {params.outdir}/$(basename {input.fasta}).out.gff {output.gff}
        mv {params.outdir}/$(basename {input.fasta}).out {output.out}
        mv {params.outdir}/$(basename {input.fasta}).masked {output.masked}
        """

