rule combine_transcript_features:
    """Combine TE features from both transcript types."""
    input:
        pc_features = f"{OUTPUT_DIR}/features/pc_transcripts_te_features.csv",
        lncrna_features = f"{OUTPUT_DIR}/features/lncrna_transcripts_te_features.csv",
        pc_regional = f"{OUTPUT_DIR}/features/pc_transcripts_regional_te_features.csv",
        lncrna_regional = f"{OUTPUT_DIR}/features/lncrna_transcripts_regional_te_features.csv"
    output:
        combined = f"{OUTPUT_DIR}/combined/all_transcripts_te_features.csv"
    run:
        import pandas as pd

        # Load features
        pc_df = pd.read_csv(input.pc_features)
        lncrna_df = pd.read_csv(input.lncrna_features)

        # Add group labels - MODIFIED: based on file source
        pc_df['group'] = 'Coding'
        lncrna_df['group'] = 'lncRNA'

        # Concatenate
        combined = pd.concat([pc_df, lncrna_df], ignore_index=True)

        # Try to merge regional features if they exist
        try:
            pc_regional = pd.read_csv(input.pc_regional)
            if not pc_regional.empty:
                lncrna_regional = pd.read_csv(input.lncrna_regional)

                pc_regional['group'] = 'Coding'
                lncrna_regional['group'] = 'lncRNA'

                regional_combined = pd.concat([pc_regional, lncrna_regional],
                                            ignore_index=True)
                combined = combined.merge(regional_combined,
                                         on=['transcript_id', 'group'],
                                         how='left')
        except:
            pass

        # Save
        combined.to_csv(output.combined, index=False)

