# ============================================================================
# Step 2: Extract transcript coordinates from FASTA headers
# ============================================================================

rule extract_transcript_bed_from_fasta:
    """Extract transcript coordinates from FASTA file into BED format."""
    input:
        fasta = "{fasta_file}"
    output:
        bed = "{output_dir}/annotation/{transcript_type}_transcripts.bed"
    params:
        transcript_type = "{transcript_type}"
    shell:
        """
        # Extract from FASTA headers: seq_id length count in_db
        # Format: >ENST00000456328.2|ENSG00000223972.5|OTTHUMG00000000961.2|OTTHUMT00000362751.1|DDX11L1-202|DDX11L1|1657|PAR|
        # Extract transcript ID and create BED entry
        grep "^>" {input.fasta} | \
            sed 's/^>//g' | \
            awk 'BEGIN {{OFS="\t"}} {{
                split($0, a, "|");
                tx_id = a[1];
                split(tx_id, b, "\.");
                print b[1], 0, a[7], b[1], 0, "+", a[7]
            }}' > {output.bed}
        """

